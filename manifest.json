{
  "name": "Gaming Addict",
  "description": "Right-click a game name in a page and easily search for gameplay videos, deals, store pages,..",
  "version": "1.2",
  "manifest_version": 3,
  "permissions": [
    "contextMenus", 
    "activeTab",
    "tabs",
    "scripting"
  ],
  "background": {
    "scripts": ["main.js"]
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
 },
 "browser_specific_settings": {
  "gecko": {
    "id": "gamingaddict@example.com"
  }
}
}
